{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pressluft.dev/schemas/profile.schema.json",
  "title": "Pressluft Ops Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key",
    "name",
    "version",
    "description",
    "configure_guarantee",
    "support",
    "base_image",
    "image_policy",
    "baseline",
    "artifacts",
    "verification"
  ],
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "configure_guarantee": {
      "type": "string",
      "minLength": 1
    },
    "support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "reason"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "supported",
            "experimental",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "base_image": {
      "type": "string",
      "minLength": 1
    },
    "image_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_override",
        "allowed"
      ],
      "properties": {
        "allow_override": {
          "type": "boolean"
        },
        "allowed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_update",
        "packages",
        "directories",
        "users",
        "firewall",
        "verification"
      ],
      "properties": {
        "package_update": {
          "type": "string",
          "enum": [
            "dist"
          ]
        },
        "packages": {
          "$ref": "#/$defs/stringArray"
        },
        "directories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/directory"
          }
        },
        "users": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/user"
          }
        },
        "firewall": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "default_incoming",
            "default_outgoing",
            "allowed_tcp_ports"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "default_incoming": {
              "type": "string",
              "enum": [
                "deny"
              ]
            },
            "default_outgoing": {
              "type": "string",
              "enum": [
                "allow"
              ]
            },
            "allowed_tcp_ports": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            }
          }
        },
        "verification": {
          "$ref": "#/$defs/verification"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "playbook",
        "role",
        "loading_model"
      ],
      "properties": {
        "playbook": {
          "type": "string",
          "const": "ansible/playbooks/configure.yml"
        },
        "role": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "loading_model": {
          "type": "string",
          "const": "dynamic-include-role"
        }
      }
    },
    "verification": {
      "$ref": "#/$defs/verification"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "directory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "owner",
        "group",
        "mode"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "group": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "pattern": "^[0-7]{4}$"
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "group",
        "home",
        "shell",
        "system"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "group": {
          "type": "string",
          "minLength": 1
        },
        "home": {
          "type": "string",
          "pattern": "^/"
        },
        "shell": {
          "type": "string",
          "pattern": "^/"
        },
        "system": {
          "type": "boolean"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "services",
        "files",
        "listeners",
        "health_checks"
      ],
      "properties": {
        "services": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "state"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "state": {
                "type": "string",
                "enum": [
                  "started"
                ]
              }
            }
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^/"
              }
            }
          }
        },
        "listeners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "host",
              "port",
              "state"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "host": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "state": {
                "type": "string",
                "enum": [
                  "started"
                ]
              }
            }
          }
        },
        "health_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "command"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "command": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
